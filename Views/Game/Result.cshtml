@model JuegoColores.Models.GameSession

@{
    ViewData["Title"] = "Resultado de la Partida";
    bool isWin = Model.State == JuegoColores.Models.GameState.Won;
    var bgClass = isWin ? "bg-success" : "bg-danger";
    var textClass = isWin ? "text-success" : "text-danger";
    var emoji = isWin ? "🎉" : "💥";
    var timeStr = string.Format("{0:mm':'ss'.'f}", Model.Stopwatch.Elapsed);
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 col-lg-6 text-center">
        <div class="card border-0 shadow-lg rounded-5 overflow-hidden">
            <div class="card-header @bgClass text-white py-4">
                <h1 class="display-4 fw-bold mb-0">@(isWin ? "¡VICTORIA!" : "¡DERROTA!") @emoji</h1>
            </div>
            <div class="card-body p-5">
                
                @if (isWin)
                {
                    if (Model.Mode == JuegoColores.Models.GameMode.Elimination)
                    {
                        var winner = Model.Players.FirstOrDefault(p => !p.IsEliminated);
                        <h3 class="mb-4 text-dark">¡Tenemos un Sobreviviente!</h3>
                        <p class="fs-4 text-primary fw-bold display-6">@winner?.Name ha ganado el juego tras @Model.CurrentRound rondas.</p>
                    }
                    else
                    {
                        <h3 class="mb-4 text-dark">¡El equipo ha superado el desafío!</h3>
                        <p class="fs-5 text-muted">Todos los jugadores lograron decir una palabra sin repetir.</p>
                    }
                }
                else
                {
                    <h3 class="mb-4 text-dark">Alguien se equivocó...</h3>
                    <div class="alert alert-danger fs-4 fw-bold mb-4 py-3">
                        El jugador que falló fue:<br />
                        <span class="display-6">@Model.LosingPlayerName</span>
                    </div>
                }

                <div class="row text-center mt-5 mb-4">
                    <div class="col-6 border-end">
                        <p class="text-muted text-uppercase mb-1 fw-semibold">Tiempo Total</p>
                        <p class="fs-1 fw-bold font-monospace @textClass">@timeStr</p>
                    </div>
                    <div class="col-6">
                        <p class="text-muted text-uppercase mb-1 fw-semibold">Jugadores</p>
                        <p class="fs-1 fw-bold text-dark">@Model.Players.Count</p>
                    </div>
                </div>

                <div class="mt-4 mb-5 text-start bg-light p-4 rounded-4 shadow-sm border">
                    <h4 class="mb-3 border-bottom pb-2">Respuestas de la Ronda</h4>
                    <ul class="list-group list-group-flush bg-transparent">
                        @foreach(var player in Model.Players)
                        {
                            <li class="list-group-item bg-transparent d-flex justify-content-between align-items-center fs-5">
                                <div>
                                    <span class="fw-bold @(player.IsEliminated ? "text-danger text-decoration-line-through" : "")">@player.Name</span>
                                    @if(player.IsEliminated)
                                    {
                                        <span class="badge bg-danger ms-2">Eliminado</span>
                                    }
                                    else if(Model.Mode == JuegoColores.Models.GameMode.Elimination && isWin)
                                    {
                                        <span class="badge bg-warning text-dark ms-2">👑 Ganador</span>
                                    }
                                </div>
                                <div class="d-flex flex-wrap gap-1 justify-content-end w-50">
                                    @if(player.AllAnsweredWords.Any())
                                    {
                                        foreach(var w in player.AllAnsweredWords)
                                        {
                                            <span class="badge bg-primary rounded-pill">@w</span>
                                        }
                                        if (player.IsEliminated && !string.IsNullOrEmpty(player.WordAnswered) && !player.AllAnsweredWords.Contains(player.WordAnswered))
                                        {
                                            <span class="badge bg-danger rounded-pill">@player.WordAnswered</span>
                                        }
                                    }
                                    else if (!string.IsNullOrEmpty(player.WordAnswered))
                                    {
                                         <span class="badge bg-danger rounded-pill">@player.WordAnswered</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">Sin responder</span>
                                    }
                                </div>
                            </li>
                        }
                    </ul>
                    <div class="mt-4 text-start border-top pt-4">
                        <h5 class="fw-bold text-muted mb-3"><i class="bi bi-pencil-square"></i> Dejar una nota en esta partida</h5>
                        <form asp-action="AddAnnotation" method="post" class="d-flex flex-column gap-3">
                            <textarea name="annotation" class="form-control bg-light fs-5" rows="2" placeholder="Agrega un comentario (Ej. 'Jugamos con la regla de 2 segundos')."></textarea>
                            <div>
                                <button type="submit" class="btn btn-outline-success">Guardar Nota y Ver Récords</button>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="mt-5 d-flex flex-column gap-3">
                    <form asp-action="EndSession" method="post">
                        <button type="submit" class="btn btn-outline-secondary w-100 btn-lg rounded-pill fw-bold">Volver al Inicio</button>
                    </form>
                    <a asp-action="Setup" class="btn btn-primary btn-lg rounded-pill shadow-sm fw-bold">Jugar De Nuevo</a>
                    <a asp-controller="Leaderboard" asp-action="Index" class="btn btn-info text-white btn-lg rounded-pill shadow-sm fw-bold">Ver Leaderboard</a>
                </div>
            </div>
        </div>
    </div>
</div>
