@model JuegoColores.Models.ViewModels.SetupViewModel

@{
    ViewData["Title"] = "Configuración de Partida";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-header bg-primary text-white text-center rounded-top-4 py-3">
                <h3 class="mb-0 fw-bold">Nueva Partida</h3>
            </div>
            <div class="card-body p-4">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <form asp-action="Setup" method="post">
                    <div class="mb-4">
                        <label asp-for="Topic" class="form-label fw-bold">Temática (ej: Colores, Países)</label>
                        <input asp-for="Topic" class="form-control form-control-lg" placeholder="Escribe la temática aquí..." required />
                        <span asp-validation-for="Topic" class="text-danger"></span>
                    </div>

                    <h5 class="fw-bold mb-3">Jugadores</h5>
                    <div id="players-container">
                        @for (int i = 0; i < 2; i++)
                        {
                            <div class="input-group mb-2 player-input">
                                <span class="input-group-text bg-light">👤</span>
                                <input name="PlayerNames" class="form-control form-control-lg" placeholder="Nombre del jugador" required />
                            </div>
                        }
                    </div>

                    <button type="button" class="btn btn-outline-secondary mb-4 w-100" id="add-player-btn">
                        + Añadir otro jugador
                    </button>

                    <div class="d-grid mt-2">
                        <button type="submit" class="btn btn-success btn-lg py-3 rounded-pill fw-bold shadow-sm">
                            ¡Comenzar Partida! 🚀
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('add-player-btn').addEventListener('click', function() {
            const container = document.getElementById('players-container');
            const div = document.createElement('div');
            div.className = 'input-group mb-2 player-input';
            div.innerHTML = `
                <span class="input-group-text bg-light">👤</span>
                <input name="PlayerNames" class="form-control form-control-lg" placeholder="Nombre del jugador" required />
                <button type="button" class="btn btn-outline-danger remove-player-btn">X</button>
            `;
            container.appendChild(div);
        });

        document.getElementById('players-container').addEventListener('click', function(e) {
            if (e.target.classList.contains('remove-player-btn')) {
                e.target.parentElement.remove();
            }
        });
    </script>
}
