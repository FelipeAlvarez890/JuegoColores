@model JuegoColores.Models.GameSession

@{
    ViewData["Title"] = "Jugando";
    var currentPlayer = Model.Players.FirstOrDefault(p => p.Id == Model.CurrentPlayerId);
}

<div class="text-center mt-3">
    <div class="d-flex justify-content-center gap-2 mb-2">
        <div class="badge bg-secondary fs-5">Tema: @Model.Topic</div>
        @if (Model.Mode == JuegoColores.Models.GameMode.Elimination)
        {
            <div class="badge bg-danger fs-5">Ronda: @Model.CurrentRound</div>
        }
    </div>

    @if (TempData["AlertMessage"] != null)
    {
        <div class="alert alert-danger fw-bold fs-4 animate-pulse shadow-sm my-3 border-danger border-2 text-dark bg-danger bg-opacity-25" role="alert">
            💥 @TempData["AlertMessage"]
        </div>
    }

    @if (Model.State == JuegoColores.Models.GameState.RoundBreak)
    {
        <div class="my-5">
            <h1 class="display-3 fw-bold text-success animate-pulse">¡Ronda Superada!</h1>
            <p class="lead mt-3">Todos los participantes sobrevivieron. Prepárense para la siguiente ronda.</p>
            <form asp-action="StartNextRound" method="post" class="mt-4">
                <button type="submit" class="btn btn-primary btn-lg shadow-lg px-5 py-3 rounded-pill fw-bold">Comenzar Ronda @(Model.CurrentRound + 1) 🚀</button>
            </form>
        </div>
    }
    else
    {
        <div class="my-4">
            <h2 class="text-muted fw-bold mb-1">Turno de:</h2>
            <h1 class="display-1 fw-bold text-primary animate-pulse">@(currentPlayer?.Name ?? "N/A")</h1>
        </div>

    <div class="d-flex justify-content-center align-items-center mb-5">
        <div class="display-4 fw-bold font-monospace bg-dark text-white rounded p-3 shadow-lg" id="timer-display">
            00:00.0
        </div>
    </div>

    <div class="row justify-content-center g-4">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-lg p-3 bg-light rounded-4">
                <form asp-action="SubmitTurn" method="post" id="turn-form">
                    <div class="mb-4">
                        <label for="word" class="form-label fw-bold">Palabra dicha (requerida)</label>
                        <input type="text" id="word" name="word" class="form-control form-control-lg text-center fs-3" autocomplete="off" required />
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary btn-lg py-4 fw-bold fs-4 rounded-3 shadow-sm">
                            Siguiente ➡️
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    }

    @if (Model.Players.Any(p => p.IsEliminated))
    {
        <div class="mt-5 text-start w-50 mx-auto border-top pt-4 border-danger">
            <h5 class="text-danger mb-3">👻 Jugadores Eliminados</h5>
            <div class="d-flex flex-wrap gap-2">
                @foreach (var p in Model.Players.Where(x => x.IsEliminated))
                {
                    <span class="badge bg-outline-danger border border-danger text-danger p-2">@p.Name (Dijo: @p.WordAnswered)</span>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
        <script>
            const initialSeconds = @(Model.Stopwatch.Elapsed.TotalSeconds.ToString(System.Globalization.CultureInfo.InvariantCulture));
            const startTime = Date.now() - (initialSeconds * 1000);

            function updateTimer() {
                const now = Date.now();
                const elapsed = Math.floor((now - startTime) / 100); // Decimas de segundo
                
                const deciseconds = elapsed % 10;
                const seconds = Math.floor(elapsed / 10) % 60;
                const minutes = Math.floor(elapsed / 600);

                const timerElem = document.getElementById('timer-display');
                if (timerElem) {
                    timerElem.innerText = 
                        `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}.${deciseconds}`;
                }
                requestAnimationFrame(updateTimer);
            }

            requestAnimationFrame(updateTimer);

            // Focus en el campo de palabra
            const wordInput = document.getElementById('word');
            if (wordInput) wordInput.focus();
        </script>
    <style>
        .animate-pulse {
            animation: pulse-animation 2s infinite;
        }
        @@keyframes pulse-animation {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); color: #0d6efd; }
            100% { transform: scale(1); }
        }
    </style>
}
