@model IEnumerable<JuegoColores.Models.LeaderboardEntry>

@{
    ViewData["Title"] = "Leaderboard";
}

<div class="row justify-content-center mt-5">
    <div class="col-lg-10">
        <div class="card border-0 shadow-lg rounded-4">
            <div class="card-header bg-dark text-white rounded-top-4 py-3 d-flex justify-content-between align-items-center">
                <h3 class="mb-0 fw-bold">🏆 Salón de la Fama</h3>
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light btn-sm rounded-pill px-3">Volver</a>
            </div>
            <div class="card-body p-0">
                @if (!Model.Any())
                {
                    <div class="p-5 text-center text-muted">
                        <h4>No hay partidas registradas aún.</h4>
                        <p>¡Juega la primera partida para aparecer aquí!</p>
                        <a asp-controller="Game" asp-action="Setup" class="btn btn-primary mt-3 rounded-pill px-4">Jugar Ahora</a>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover table-striped mb-0 text-center align-middle">
                            <thead class="table-dark">
                                <tr>
                                    <th scope="col" class="py-3">Modo</th>
                                    <th scope="col" class="py-3">Rondas</th>
                                    <th scope="col" class="py-3">Jugadores</th>
                                    <th scope="col" class="py-3">Tiempo Total</th>
                                    <th scope="col" class="py-3">Resultado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in Model)
                                {
                                    bool isWin = entry.Result == "Won";
                                    <tr>
                                        <td class="fw-bold">@(entry.Mode == JuegoColores.Models.GameMode.Elimination ? "Supervivencia" : "Cooperativo")</td>
                                        <td>@entry.TotalRounds</td>
                                        <td>@entry.PlayerCount 👤</td>
                                        <td class="font-monospace fw-bold @((isWin) ? "text-success" : "text-danger")">
                                            @TimeSpan.FromSeconds(entry.TotalTimeSeconds).ToString(@"mm\:ss\.ff")
                                        </td>
                                        <td>
                                            @if (isWin)
                                            {
                                                <span class="badge bg-success fs-6 rounded-pill px-3 py-2">Victoria 🎉</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger fs-6 rounded-pill px-3 py-2">Derrota 💥</span>
                                            }
                                        </td>
                                    </tr>
                                    @if (!string.IsNullOrEmpty(entry.Annotation))
                                    {
                                        <tr>
                                            <td colspan="5" class="text-start bg-light fst-italic text-muted pt-2 pb-3 ps-4 border-bottom">
                                                <span class="fw-bold text-dark">Nota:</span> @entry.Annotation
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
